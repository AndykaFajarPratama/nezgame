# ─── App ───
NODE_ENV=development
PORT=3000
APP_DOMAIN=https://nezgame.onrender.com

# ─── Database (Postgres) ───
DATABASE_URL=postgresql://user:password@localhost:5432/nezgame

# ─── Better Auth ───
BETTER_AUTH_SECRET=change-me-to-a-random-secret-key
BETTER_AUTH_URL=http://localhost:3000

# ─── Apigame ───
APIGAME_MERCHANT_ID=your_apigame_merchant_id
APIGAME_SECRET_KEY=your_apigame_secret_key

# ─── Midtrans ───
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_IS_PRODUCTION=false

# ─── Pricing ───
PRODUCT_MARKUP_FLAT=2000
